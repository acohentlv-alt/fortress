# Fortress B2B Lead Collection — Environment Variables
# Copy to .env and fill in your values.

# ── Database ────────────────────────────────────────────────────
# Option 1 (recommended): Single connection string (Neon, Render, etc.)
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Option 2: Individual parts (local development)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fortress
# DB_USER=fortress
# DB_PASSWORD=fortress_dev

# ── Security ────────────────────────────────────────────────────
# Session cookie signing key — MUST be a random string in production
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=fortress-dev-secret-change-me

# ── Frontend ────────────────────────────────────────────────────
# Set to your production URL for CORS and secure cookies
# When this starts with https://, cookies get the Secure flag automatically
FRONTEND_URL=http://localhost:8080

# ── INPI API (optional) ────────────────────────────────────────
# INPI_USERNAME=your_username
# INPI_PASSWORD=your_password

# ── Rate Limiting ───────────────────────────────────────────────
DELAY_BETWEEN_REQUESTS_MIN=2.0
DELAY_BETWEEN_REQUESTS_MAX=4.0
MAX_CONCURRENT_SCRAPERS=3
