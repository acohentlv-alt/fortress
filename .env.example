# Fortress B2B Lead Collection — Environment Variables
# Copy to .env and fill in your values.

# ── PostgreSQL (native local install or Docker) ─────────────────
# Default assumes a local Postgres running on localhost:5432.
# If using Docker, update the port/credentials accordingly.
FORTRESS_DB_URL=postgresql://fortress:fortress_dev@localhost:5432/fortress

# ── INPI API (Recherche Entreprises) ────────────────────────────
# Optional: INPI bearer token for officer data.
# Without it, Steps 2 (INPI batch) will be skipped.
# INPI_BEARER_TOKEN=your_token_here

# ── Rate Limiting ───────────────────────────────────────────────
# Delay between requests (seconds) — randomized between min and max.
DELAY_BETWEEN_REQUESTS_MIN=2.0
DELAY_BETWEEN_REQUESTS_MAX=4.0

# Max concurrent scraper threads per batch.
MAX_CONCURRENT_SCRAPERS=3
