#!/bin/sh
# Pre-push deploy guard for Fortress.
# Warns if any batch is queued/in_progress/triage when pushing to main.
# Per CLAUDE.md: Cindy actively uses prod; Render redeploy kills running batches.
#
# Install: bash scripts/install_hooks.sh
# Bypass:  git push --no-verify (NOT RECOMMENDED — kills active batches silently)

remote="$1"

# Read each ref being pushed; only check on pushes that include refs/heads/main
PUSHING_MAIN=0
while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_ref" = "refs/heads/main" ]; then
        PUSHING_MAIN=1
    fi
done

if [ "$PUSHING_MAIN" -eq 0 ]; then
    exit 0
fi

# Run the active-batch check
python3 scripts/check_active_batches.py
RESULT=$?

if [ "$RESULT" -eq 0 ]; then
    exit 0
fi

# Active batches found — prompt
printf "\nProceed with push and kill these batches? (y/N) " >&2
read -r answer </dev/tty
case "$answer" in
    [yY]|[yY][eE][sS])
        echo "Pushing despite active batches..." >&2
        exit 0
        ;;
    *)
        echo "Push aborted." >&2
        exit 1
        ;;
esac
